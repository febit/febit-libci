        "assert_exists() {\n  local file=\"$1\"\n  test -f \"$file\" || {\n    echo \"[ERROR] missing expected marker: $file\"\n    exit 1\n  }\n}\n\nassert_absent() {\n  local file=\"$1\"\n  if [ -e \"$file\" ]; then\n    echo \"[ERROR] unexpected marker present: $file\"\n    exit 1\n  fi\n}\n\nassert_contains() {\n  local file=\"$1\"\n  local expected=\"$2\"\n  grep -F \"$expected\" \"$file\" >/dev/null || {\n    echo \"[ERROR] expected '$expected' in $file\"\n    exit 1\n  }\n}\n\nassert_exists reports/success-anchor.log\nassert_exists reports/run-on-success-before-failure.log\nassert_exists reports/run-always-before-failure.log\nassert_exists reports/trigger-pipeline-failure.log\nassert_exists reports/run-on-failure-after-failure.log\nassert_exists reports/run-always-after-failure.log\n\nassert_absent reports/skip-on-failure-before-failure.log\nassert_absent reports/skip-on-success-after-failure.log\n\nassert_contains reports/success-anchor.log 'success-anchor:ran'\nassert_contains reports/run-on-success-before-failure.log 'run-on-success-before-failure:ran'\nassert_contains reports/run-always-before-failure.log 'run-always-before-failure:ran'\nassert_contains reports/trigger-pipeline-failure.log 'trigger-pipeline-failure:about-to-fail'\nassert_contains reports/run-on-failure-after-failure.log 'run-on-failure-after-failure:ran'\nassert_contains reports/run-always-after-failure.log 'run-always-after-failure:ran'\n"
