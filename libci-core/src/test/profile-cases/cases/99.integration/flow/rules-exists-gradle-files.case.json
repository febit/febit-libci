        "assert_exists() {\n  file=\"$1\"\n  test -f \"$file\" || {\n    echo \"[ERROR] missing expected file: $file\"\n    exit 1\n  }\n}\n\nassert_absent() {\n  file=\"$1\"\n  if [ -e \"$file\" ]; then\n    echo \"[ERROR] unexpected file present: $file\"\n    exit 1\n  fi\n}\n\nassert_contains() {\n  file=\"$1\"\n  expected=\"$2\"\n  grep -F \"$expected\" \"$file\" >/dev/null || {\n    echo \"[ERROR] expected '$expected' in $file\"\n    exit 1\n  }\n}\n\nassert_exists reports/root-gradle-file-exists.log\nassert_exists reports/nested-gradle-file-exists.log\nassert_exists reports/multiple-gradle-files-exist.log\n\nassert_absent reports/missing-gradle-file-falls-through.log\nassert_absent reports/mixed-gradle-files-fall-through.log\n\nassert_contains reports/root-gradle-file-exists.log 'root-gradle-file-exists:ran'\nassert_contains reports/root-gradle-file-exists.log 'matched:build.gradle'\nassert_contains reports/nested-gradle-file-exists.log 'nested-gradle-file-exists:ran'\nassert_contains reports/nested-gradle-file-exists.log 'matched:gradle/wrapper/gradle-wrapper.properties'\nassert_contains reports/multiple-gradle-files-exist.log 'multiple-gradle-files-exist:ran'\nassert_contains reports/multiple-gradle-files-exist.log 'matched:build.gradle'\nassert_contains reports/multiple-gradle-files-exist.log 'matched:gradle/wrapper/gradle-wrapper.properties'\n"
