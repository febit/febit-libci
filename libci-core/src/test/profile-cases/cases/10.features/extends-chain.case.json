{
  "variables": {},
  "workflow": {
    "auto_cancel": {
      "on_new_commit": "conservative",
      "on_job_failure": "none"
    },
    "rules": []
  },
  "stages": [
    ".pre",
    "test",
    ".post"
  ],
  "jobs": {
    "test-extends-chain": {
      "name": "test-extends-chain",
      "stage": "test",
      "image": {
        "name": "eclipse-temurin:21-jre"
      },
      "services": [],
      "tags": [],
      "inherit": {
        "default": true,
        "variables": true
      },
      "timeout": "never",
      "when": "on_success",
      "allow_failure": {
        "value": false,
        "exit_codes": []
      },
      "retry": {
        "max": 0,
        "when": [
          "always"
        ],
        "exit_codes": []
      },
      "id_tokens": {},
      "before_script": [
        "echo base-image-before"
      ],
      "script": [
        "echo test-extends-chain"
      ],
      "after_script": [],
      "hooks": {},
      "interruptible": true,
      "variables": {
        "FROM_RUNTIME": {
          "value": "runtime",
          "expand": true
        }
      },
      "artifacts": {
        "name": "artifacts",
        "public": true,
        "untracked": false,
        "when": "always",
        "access": "all",
        "paths": [
          "reports/base-image.txt"
        ],
        "exclude": [],
        "reports": {}
      },
      "cache": {
        "key": {
          "value": "shared-cache",
          "files": []
        },
        "untracked": false,
        "unprotect": false,
        "when": "on_success",
        "policy": "pull-push",
        "paths": [
          ".gradle/"
        ],
        "fallback_keys": []
      },
      "rules": []
    }
  }
}
