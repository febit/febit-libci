{
  "stages": [
    "build",
    "deploy"
  ],
  "advanced-job": {
    "stage": "build",
    "image": {
      "name": "eclipse-temurin:21",
      "docker": {
        "platform": "linux/amd64",
        "user": "1000"
      },
      "entrypoint": [
        "/bin/sh",
        "-lc"
      ]
    },
    "services": [
      {
        "name": "redis:7",
        "alias": [
          "cache",
          "redis"
        ],
        "entrypoint": [
          "/bin/sh"
        ],
        "command": [
          "-lc",
          "redis-server"
        ]
      }
    ],
    "hooks": {
      "pre_get_sources_script": [
        "git config --global advice.detachedHead false"
      ]
    },
    "id_tokens": {
      "vault": {
        "aud": [
          "https://vault.example.test",
          "https://vault-backup.example.test"
        ]
      }
    },
    "cache": {
      "key": {
        "prefix": "build",
        "files": [
          "gradle/libs.versions.toml",
          "settings.gradle"
        ]
      },
      "fallback_keys": [
        "build-default",
        "build-shared"
      ],
      "paths": [
        ".gradle/",
        "build/cache/"
      ],
      "when": "always",
      "policy": "pull",
      "unprotect": true
    },
    "environment": {
      "name": "review/$CI_COMMIT_REF_SLUG",
      "action": "prepare",
      "url": "https://review.example.test/$CI_COMMIT_REF_SLUG",
      "auto_stop_in": "3 days",
      "kubernetes": {
        "agent": "ops/review",
        "namespace": "review-$CI_COMMIT_REF_SLUG",
        "flux_resource_path": "clusters/review"
      }
    },
    "script": [
      "./gradlew test"
    ]
  },
  "release-job": {
    "stage": "deploy",
    "release": {
      "tag_name": "$CI_COMMIT_TAG",
      "tag_message": "release tag",
      "name": "Release $CI_COMMIT_TAG",
      "description": "release notes",
      "ref": "main",
      "milestones": [
        "m1",
        "m2"
      ],
      "released_at": "2026-01-01T00:00:00Z",
      "assets": {
        "links": [
          {
            "name": "docs",
            "url": "https://example.test/docs",
            "filepath": "/docs",
            "link_type": "runbook"
          }
        ]
      }
    },
    "trigger": {
      "project": "group/downstream",
      "branch": "main",
      "strategy": "depend",
      "include": [
        {
          "local": "child.yml"
        },
        {
          "project": "group/shared",
          "ref": "main",
          "file": [
            "child-a.yml",
            "child-b.yml"
          ],
          "inputs": {
            "DEPLOY_ENV": "prod"
          }
        }
      ],
      "forward": {
        "yaml_variables": true,
        "pipeline_variables": false
      },
      "inputs": {
        "DEPLOY_ENV": "prod"
      }
    },
    "secrets": {
      "DATABASE_PASSWORD": {
        "vault": {
          "engine": {
            "name": "kv-v2",
            "path": "ops"
          },
          "path": "production/db",
          "field": "password"
        },
        "token": "VAULT_ID_TOKEN",
        "file": false
      },
      "API_KEY": {
        "gcp_secret_manager": {
          "name": "api-key",
          "version": "latest"
        }
      },
      "AZURE_TOKEN": {
        "azure_key_vault": {
          "name": "azure-token",
          "version": "latest"
        }
      }
    },
    "pages": {
      "publish": "dist",
      "path_prefix": "docs",
      "expire_in": "never"
    },
    "script": [
      "echo release"
    ]
  }
}
