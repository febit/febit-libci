{
  "variables": {},
  "workflow": {
    "auto_cancel": {
      "on_new_commit": "conservative",
      "on_job_failure": "none"
    },
    "rules": []
  },
  "stages": [
    ".pre",
    "build",
    "test",
    "package",
    ".post"
  ],
  "jobs": {
    "build-output": {
      "name": "build-output",
      "stage": "build",
      "image": {
        "name": "alpine:latest"
      },
      "services": [],
      "tags": [],
      "inherit": {
        "default": true,
        "variables": true
      },
      "timeout": "never",
      "when": "on_success",
      "allow_failure": {
        "value": false,
        "exit_codes": []
      },
      "retry": {
        "max": 0,
        "when": [
          "always"
        ],
        "exit_codes": []
      },
      "id_tokens": {},
      "before_script": [],
      "script": [
        "echo build-output"
      ],
      "after_script": [],
      "hooks": {},
      "interruptible": false,
      "variables": {},
      "artifacts": {
        "name": "artifacts",
        "public": true,
        "untracked": false,
        "when": "on_success",
        "access": "all",
        "paths": [
          "build/output.txt"
        ],
        "exclude": [],
        "reports": {}
      },
      "rules": []
    },
    "package-with-structured-needs": {
      "name": "package-with-structured-needs",
      "stage": "package",
      "image": {
        "name": "alpine:latest"
      },
      "services": [],
      "tags": [],
      "inherit": {
        "default": true,
        "variables": true
      },
      "timeout": "never",
      "when": "on_success",
      "allow_failure": {
        "value": false,
        "exit_codes": []
      },
      "retry": {
        "max": 0,
        "when": [
          "always"
        ],
        "exit_codes": []
      },
      "id_tokens": {},
      "before_script": [],
      "script": [
        "echo package-with-structured-needs"
      ],
      "after_script": [],
      "hooks": {},
      "interruptible": false,
      "variables": {},
      "rules": [],
      "needs": [
        {
          "job": "build-output",
          "artifacts": false
        },
        {
          "job": "test-with-needs",
          "optional": false
        }
      ],
      "dependencies": [
        "build-output",
        "test-with-needs"
      ]
    },
    "test-with-needs": {
      "name": "test-with-needs",
      "stage": "test",
      "image": {
        "name": "alpine:latest"
      },
      "services": [],
      "tags": [],
      "inherit": {
        "default": true,
        "variables": true
      },
      "timeout": "never",
      "when": "on_success",
      "allow_failure": {
        "value": false,
        "exit_codes": []
      },
      "retry": {
        "max": 0,
        "when": [
          "always"
        ],
        "exit_codes": []
      },
      "id_tokens": {},
      "before_script": [],
      "script": [
        "echo TOTAL 98%"
      ],
      "after_script": [],
      "hooks": {},
      "interruptible": true,
      "variables": {},
      "coverage": "/TOTAL.+ ([0-9]{1,3}%)/",
      "rules": [],
      "needs": [
        {
          "job": "build-output"
        }
      ],
      "dependencies": [
        "build-output"
      ]
    }
  }
}
